<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Natasha Gan | Senior Project Manager</title>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@200;300;400;500;700&display=swap');
        
        :root {
            --bg-color: #FAF9F6;
            --text-color: #333;
            --accent-color: #D4AF37; /* 金色 */
            --dark-bg: #1A1A1A;
            --dark-text: #F0F0F0;
            --grey: #808080;
        }

        body {
            font-family: 'Inter', sans-serif;
            margin: 0;
            background-color: var(--bg-color);
            color: var(--text-color);
            scroll-behavior: smooth;
        }

        /* 導航欄 */
        nav {
            position: fixed;
            width: 100%;
            background-color: rgba(250, 249, 246, 0.9);
            backdrop-blur: md;
            z-index: 50;
            border-bottom: 1px solid #E0E0E0;
            padding: 1rem 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        nav h1 {
            text-size: 1.25rem;
            font-weight: 200;
            letter-spacing: 0.3em;
            text-transform: uppercase;
            margin: 0;
        }

        .nav-links {
            display: flex;
            gap: 2rem;
        }

        .nav-links a {
            text-decoration: none;
            color: var(--grey);
            font-size: 0.625rem;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            font-weight: 500;
            transition: color 0.3s;
        }

        .nav-links a:hover {
            color: black;
        }

        /* Hero 區塊 */
        #about {
            min-height: 100vh;
            display: flex;
            align-items: center;
            padding: 6rem 1.5rem 0;
            max-width: 1280px;
            margin: 0 auto;
        }

        .hero-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4rem;
            width: 100%;
        }

        @media (min-width: 768px) {
            .hero-container {
                flex-direction: row;
                text-align: left;
            }
        }

        .profile-pic {
            position: relative;
            width: 16rem;
            height: 16rem;
            flex-shrink: 0;
            border-radius: 50%;
            border: 8px solid white;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            overflow: hidden;
            background-color: #F0F0F0;
        }

        @media (min-width: 768px) {
            .profile-pic {
                width: 20rem;
                height: 20rem;
            }
        }

        .profile-pic img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            filter: grayscale(100%);
        }

        .hero-text {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 2rem;
            text-align: center;
        }

        @media (min-width: 768px) {
            .hero-text {
                text-align: left;
            }
        }

        .hero-text h2 {
            font-size: 0.625rem;
            font-weight: 700;
            letter-spacing: 0.4em;
            color: #B0B0B0;
            text-transform: uppercase;
            margin: 0 0 1rem;
        }

        .hero-text h1 {
            font-size: 2.5rem;
            font-weight: 200;
            line-height: 1.2;
            margin: 0;
        }

        @media (min-width: 768px) {
            .hero-text h1 {
                font-size: 3.75rem;
            }
        }

        .hero-text h1 span {
            font-style: italic;
            color: var(--grey);
        }

        .hero-text p {
            font-size: 1.125rem;
            color: var(--grey);
            line-height: 1.6;
            max-width: 42rem;
            font-weight: 200;
            margin: 0;
        }

        .skills-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1rem;
            max-width: 28rem;
            margin: 0 auto;
        }

        @media (min-width: 640px) {
            .skills-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (min-width: 768px) {
            .skills-grid {
                margin: 0;
            }
        }

        .skill-item {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem 1.25rem;
            background-color: white;
            border: 1px solid #F0F0F0;
            box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            border-radius: 0.75rem;
            font-size: 0.625rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: #606060;
            font-weight: 500;
        }

        .skill-item i {
            color: #B0B0B0;
        }

        /* Portfolio Section */
        #portfolio {
            padding: 8rem 1.5rem;
            background-color: var(--dark-bg);
            color: var(--dark-text);
        }

        .section-container {
            max-width: 1280px;
            margin: 0 auto;
        }

        .section-header {
            margin-bottom: 5rem;
        }

        .section-header h2 {
            color: var(--grey);
            font-size: 0.625rem;
            font-weight: 700;
            letter-spacing: 0.4em;
            text-transform: uppercase;
            margin: 0 0 1rem;
        }

        .section-header h3 {
            font-size: 2.25rem;
            font-weight: 200;
            font-style: italic;
            margin: 0;
        }

        .projects-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 2rem;
        }

        @media (min-width: 768px) {
            .projects-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (min-width: 1024px) {
            .projects-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        .project-card {
            position: relative;
            aspect-ratio: 4/3;
            background-color: #262626;
            border-radius: 0.125rem;
            overflow: hidden;
            cursor: pointer;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            transition: transform 0.3s;
        }

        .project-card:hover {
            transform: translateY(-5px);
        }

        .project-card img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.6;
            transition: opacity 0.3s, transform 0.3s;
        }

        .project-card:hover img {
            opacity: 1;
            transform: scale(1.05);
        }

        .project-info {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            padding: 2rem;
            background: linear-gradient(to top, rgba(0, 0, 0, 0.8), transparent);
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
        }

        .project-info span {
            color: #B0B0B0;
            font-size: 0.625rem;
            font-weight: 700;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            margin-bottom: 0.5rem;
        }

        .project-info h4 {
            color: white;
            font-size: 1.25rem;
            font-weight: 200;
            margin: 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        /* Experience Section */
        #experience {
            padding: 8rem 1.5rem;
            background-color: white;
        }

        .experience-container {
            max-width: 1024px;
            margin: 0 auto;
        }

        .experience-list {
            display: flex;
            flex-direction: column;
            gap: 8rem;
        }

        .experience-item {
            display: grid;
            grid-template-columns: 1fr;
            gap: 2rem;
        }

        @media (min-width: 768px) {
            .experience-item {
                grid-template-columns: 1.2fr 2.5fr;
                gap: 4rem;
            }
        }

        .company-info {
            text-align: left;
        }

        @media (min-width: 768px) {
            .company-info {
                text-align: right;
            }
        }

        .company-info .period {
            font-family: monospace;
            font-size: 0.6875rem;
            color: #B0B0B0;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            display: block;
            margin-bottom: 0.75rem;
        }

        .company-info h3 {
            font-size: 1.5rem;
            font-weight: 200;
            line-height: 1.2;
            margin: 0;
        }

        .role-details {
            border-left: 1px solid #F0F0F0;
            padding-left: 2rem;
        }

        @media (min-width: 768px) {
            .role-details {
                padding-left: 4rem;
            }
        }

        .role-details h4 {
            font-size: 1.125rem;
            font-weight: 700;
            letter-spacing: -0.025em;
            text-transform: uppercase;
            margin: 0 0 1.5rem;
        }

        .role-details ul {
            list-style: none;
            padding: 0;
            margin: 0;
            display: flex;
            flex-direction: column;
            gap: 1rem;
            color: var(--grey);
            font-weight: 200;
            font-size: 1.125rem;
            line-height: 1.6;
        }

        /* Contact Section */
        #contact {
            padding: 8rem 1.5rem;
            background-color: var(--dark-bg);
            color: var(--dark-text);
            text-align: center;
        }

        .contact-content {
            max-width: 56rem;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            gap: 3rem;
        }

        .contact-content h3 {
            font-size: 1.875rem;
            font-weight: 200;
            font-style: italic;
            margin: 0;
        }

        @media (min-width: 768px) {
            .contact-content h3 {
                font-size: 3rem;
            }
        }

        .contact-links {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 3rem;
            font-size: 0.875rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: rgba(240, 240, 240, 0.6);
        }

        .contact-links a {
            text-decoration: none;
            color: inherit;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            transition: color 0.3s;
        }

        .contact-links a:hover {
            color: white;
        }

        .contact-links .phone {
            color: white;
            font-weight: bold;
        }

        /* 頁腳 */
        footer {
            padding: 3rem 1.5rem;
            background-color: var(--dark-bg);
            color: #606060;
            text-align: center;
            font-size: 0.625rem;
            text-transform: uppercase;
            letter-spacing: 0.3em;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }
    </style>
</head>
<body>

    <nav>
        <h1>Natasha Gan</h1>
        <div class="nav-links">
            <a href="#about">About</a>
